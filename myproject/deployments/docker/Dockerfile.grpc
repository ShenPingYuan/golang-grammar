FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/grpcserver ./cmd/grpcserver

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/grpcserver /bin/grpcserver
COPY configs/ /app/configs/
WORKDIR /app
EXPOSE 9090
CMD ["/bin/grpcserver"]